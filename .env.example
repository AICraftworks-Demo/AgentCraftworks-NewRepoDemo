# GitHub Actions MCP Server — Environment Variables
# Copy this file to .env and fill in your values.

# Required: Personal Access Token with `repo` and `workflow` scopes.
# For fine-grained PATs enable: Actions (read/write), Contents (read).
GITHUB_TOKEN=ghp_your_token_here

# Optional defaults – used when owner/repo are omitted from tool calls.
GITHUB_DEFAULT_OWNER=your-org-or-user
GITHUB_DEFAULT_REPO=your-repo-name

# Optional: Override for GitHub Enterprise Server instances.
# GITHUB_API_BASE=https://github.example.com/api/v3
